<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="12dp"
    android:background="#111">

    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="⚠️ Crash"
        android:textSize="20sp"
        android:textColor="#f44"
        android:layout_marginBottom="8dp"/>

    <ScrollView android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1">
        <TextView android:id="@+id/crashLog"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:textSize="10sp" android:textColor="#f66"
            android:fontFamily="monospace"
            android:padding="8dp"/>
    </ScrollView>

    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="All Logs:"
        android:textSize="12sp" android:textColor="#888"
        android:layout_marginTop="8dp" android:layout_marginBottom="4dp"/>

    <ScrollView android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1">
        <TextView android:id="@+id/fullLog"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:textSize="9sp" android:textColor="#0f0"
            android:fontFamily="monospace"
            android:padding="8dp"/>
    </ScrollView>

    <Button android:id="@+id/copyBtn"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:text="Copy All Logs"
        android:layout_marginTop="8dp"/>

</LinearLayout>
