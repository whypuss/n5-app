<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- 日語原文 -->
        <TextView
            android:id="@+id/japaneseText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="32sp"
            android:textStyle="bold"
            android:textColor="#fff"
            android:layout_marginBottom="8dp"/>

        <!-- 讀音 -->
        <TextView
            android:id="@+id/readingText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="18sp"
            android:textColor="#4fc3f7"
            android:layout_marginBottom="4dp"/>

        <!-- 詞性/分類 -->
        <TextView
            android:id="@+id/metaText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="12sp"
            android:textColor="#888"
            android:layout_marginBottom="8dp"/>

        <!-- 意思 -->
        <TextView
            android:id="@+id/meaningText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="20sp"
            android:textColor="#ce93d8"
            android:layout_marginBottom="16dp"/>

        <!-- 播放區 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="16dp">

            <Button
                android:id="@+id/playBtn"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="▶ 播放音頻"
                android:enabled="false"/>

            <TextView
                android:id="@+id/audioStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="..."
                android:textSize="12sp"
                android:textColor="#888"
                android:layout_marginStart="8dp"/>

        </LinearLayout>

        <!-- 詞彙表（explanation） -->
        <LinearLayout
            android:id="@+id/wordSection"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="詞彙表"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#aaa"
                android:layout_marginBottom="8dp"/>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/wordRecycler"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"/>

        </LinearLayout>

        <!-- 逐字拆解 -->
        <LinearLayout
            android:id="@+id/seqSection"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="逐字拆解"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#aaa"
                android:layout_marginBottom="8dp"/>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/seqRecycler"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"/>

        </LinearLayout>

    </LinearLayout>

</ScrollView>
